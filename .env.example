# Cloudflare R2（S3 互換）
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
BUCKET_NAME=

# R2 上のファイル名のみ（パス data/2026-02-27/ はコード内で固定）
R2_OBJECT_KEY=transition_url_item_statistics_upload.parquet

# Cloudflare API（必要に応じて）
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# キャッシュディレクトリ（省略時は ./data）
# CACHE_DIR=./data
